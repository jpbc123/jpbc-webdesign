# TODO: Set your webhook URL so /get-started leads pipe to WhatsApp/Sheets/Zapier.
# Leads are always saved locally to .data/leads.jsonl; if this is set they are
# also POSTed as JSON to this URL.
LEAD_WEBHOOK_URL=

# Per-market WhatsApp numbers (country code first, digits only, no "+").
# Leave unset and that market falls back to the Malaysian number in
# config/markets/my.ts. Values are read at build time.
PH_WHATSAPP=
AU_WHATSAPP=
